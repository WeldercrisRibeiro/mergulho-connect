# Porta do servidor backend
PORT=3001

# Conexão direta com PostgreSQL (Supabase: Settings > Database > Connection string > URI)
# Use a "Direct connection" (não pooled) para migrations do Prisma
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase (para leitura de profiles/groups via JS client - bypassar RLS)
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# URL do frontend (para CORS)
FRONTEND_URL="http://localhost:8080"
