generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tabela de disparos agendados
model WzDispatch {
  id              String                 @id @default(uuid())
  title           String
  content         String?
  type            String                 // general | group | individual
  priority        String                 @default("normal")
  target_group_id String?
  target_user_id  String?
  status          String                 @default("pending") // pending | sending | sent | error
  scheduled_at    DateTime
  sent_at         DateTime?
  error_message   String?
  created_at      DateTime               @default(now())
  created_by      String?
  attachments     WzDispatchAttachment[]
  logs            WzDispatchLog[]

  @@map("wz_dispatches")
}

// Anexos de cada disparo
model WzDispatchAttachment {
  id          String     @id @default(uuid())
  dispatch_id String
  type        String     // image | video | audio | document
  filename    String
  filepath    String
  mimetype    String
  dispatch    WzDispatch @relation(fields: [dispatch_id], references: [id], onDelete: Cascade)

  @@map("wz_dispatch_attachments")
}

// Log de cada tentativa de envio por destinatário
model WzDispatchLog {
  id          String     @id @default(uuid())
  dispatch_id String
  recipient   String     // número de telefone ou "general"
  status      String     // success | error
  error       String?
  created_at  DateTime   @default(now())
  dispatch    WzDispatch @relation(fields: [dispatch_id], references: [id], onDelete: Cascade)

  @@map("wz_dispatch_logs")
}
